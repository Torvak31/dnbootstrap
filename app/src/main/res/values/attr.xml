<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="ControlButton">
        <attr name="button_keycode" format="integer"/>
        <attr name="button_keycode2" format="integer"/>
        <attr name="sticky" format="boolean"/>
        <attr name="cursorPassThru" format="boolean"/>
    </declare-styleable>

    <declare-styleable name="ControlJoystick">
        <attr name="joystickKeyUp" format="integer" />
        <attr name="joystickKeyDown" format="integer" />
        <attr name="joystickKeyLeft" format="integer" />
        <attr name="joystickKeyRight" format="integer" />
    </declare-styleable>

    <style name="ControlJoystick">
        <!-- Default visual / behavior overrides if needed -->
    </style>


    <attr name="controlButtonStyle" format="reference"/>

    <style name="AppTheme" parent="@style/Theme.AppCompat">
        <item name="controlButtonStyle">@style/ControlButton</item>
    </style>

    <style name="ControlButton">
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:background">#3f000000</item>
        <item name="android:width">64dp</item>
        <item name="android:height">64dp</item>
    </style>
</resources>